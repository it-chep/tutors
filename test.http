### Получение информации по всем финансам
POST http://localhost:8080/admin/finance
Content-Type: application/json

{
  "from": "2006-01-02",
  "to": "2006-01-02"
}

### Получить списка учебных предметов
GET http://localhost:8080/admin/subjects


###
# Репетиторы
### Получить всех репетиторов
GET http://localhost:8080/admin/tutors/

### Получить репетитора по ID
GET http://localhost:8080/admin/tutors/1

### Поиск по репетиторам
GET http://localhost:8080/admin/tutors/search?search=Нечепорук

### Создание репетитора
POST http://localhost:8080/admin/tutors
Content-Type: application/json

{
  "full_name": "Узянов Даниил Евгеньевич",
  "phone": "+7 995 677 8781",
  "tg": "https://t.me/danzelVash",
  "cost_per_hour": "1500",
  "subject_id": 1
}

### Удаление репетитора
DELETE http://localhost:8080/admin/tutors/3

### Получение информации по финансам репетитора
POST http://localhost:8080/admin/tutors/1/finance
Content-Type: application/json

{
  "from": "2006-01-02",
  "to": "2006-01-02"
}

### Репетитор проводит демо урок
POST http://localhost:8080/admin/tutors/trial_lesson
Content-Type: application/json

{
  "student_id": 2
}

### Репетитор проводит обычный урок
POST http://localhost:8080/admin/tutors/conduct_lesson
Content-Type: application/json

{
  "student_id": 2,
  "duration": 1
}

###
# Студенты

### Получить всех студентов
GET http://localhost:8080/admin/students

### Получить студентов репетитора
GET http://localhost:8080/admin/students?tutor_id=1

### Получить информацию о студенте
GET http://localhost:8080/admin/students/1

### Поиск по студентам
GET http://localhost:8080/admin/students/search?search=Нечепорук

### Создание студента
POST http://localhost:8080/admin/students
Content-Type: application/json

{
  "first_name": "Узянов",
  "last_name": "Даниил",
  "middle_name": "Евгеньевич",
  "phone": "+7 995 677 8781",
  "tg": "https://t.me/danzelVash",
  "cost_per_hour": "1500",
  "subject_id": 1,
  "tutor_id": 1,
  "parent_full_name": "Узянов Даниил Евгеньевич",
  "parent_phone": "+7 995 677 8781",
  "parent_tg": "https://t.me/danzelVash"
}

### Удаление студента
DELETE http://localhost:8080/admin/students/1

### Перенос студентов между репами
POST http://localhost:8080/admin/students/move
Content-Type: application/json

{
  "old_tutor_id": 1,
  "new_tutor_id": 2,
  "student_id": 3
}

### Перенос студентов между репами
POST http://localhost:8080/admin/students/move
Content-Type: application/json

{
  "old_tutor_id": 2,
  "new_tutor_id": 3
}


### Получение информации по финансам студента
POST http://localhost:8080/admin/students/1/finance
Content-Type: application/json

{
  "from": "2006-01-02",
  "to": "2006-01-02"
}

###
# Админы

###
# Новые эндпоинты из коммита 042c945
@host = http://localhost:8080
@accessToken = put-access-token-here
@assistantId = 1
@tutorId = 1
@contractPath = /tmp/contract.pdf
@receiptPath = /tmp/receipt.pdf

### Обновить permissions ассистента
POST {{host}}/admin/assistant/{{assistantId}}/permissions
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "can_view_contracts": true,
  "can_penalize_assistants": [1, 2]
}

### Получить штрафы и премии ассистента
POST {{host}}/admin/assistant/{{assistantId}}/penalties-bonuses
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "from": "2026-03-01",
  "to": "2026-03-31"
}

### Создать штраф или премию ассистенту
POST {{host}}/admin/assistant/{{assistantId}}/penalties-bonuses
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "type": "bonus",
  "amount": 1500,
  "comment": "Премия за закрытие месяца"
}

### Получить начисления ассистента
POST {{host}}/admin/assistant/{{assistantId}}/accruals
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "from": "2026-03-01",
  "to": "2026-03-31"
}

### Скачать все договоры репетиторов
GET {{host}}/admin/tutors/contracts/download_all
Authorization: Bearer {{accessToken}}

### Загрузить договор репетитора
POST {{host}}/admin/tutors/{{tutorId}}/contract
Content-Type: multipart/form-data; boundary=WebAppBoundary
Authorization: Bearer {{accessToken}}

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="contract.pdf"
Content-Type: application/pdf

< {{contractPath}}
--WebAppBoundary--

### Скачать договор репетитора
GET {{host}}/admin/tutors/{{tutorId}}/contract
Authorization: Bearer {{accessToken}}

### Удалить договор репетитора
DELETE {{host}}/admin/tutors/{{tutorId}}/contract
Authorization: Bearer {{accessToken}}

### Получить штрафы и премии репетитора
POST {{host}}/admin/tutors/{{tutorId}}/penalties-bonuses
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "from": "2026-03-01",
  "to": "2026-03-31"
}

### Создать штраф или премию репетитору
POST {{host}}/admin/tutors/{{tutorId}}/penalties-bonuses
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "type": "penalty",
  "amount": 1000,
  "comment": "Штраф за перенос занятий"
}

### Получить начисления репетитора
POST {{host}}/admin/tutors/{{tutorId}}/accruals
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "from": "2026-03-01",
  "to": "2026-03-31"
}

### Создать выплату репетитору
POST {{host}}/admin/tutors/{{tutorId}}/payouts
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "amount": 25000,
  "comment": "Выплата за март"
}

### Получить список чеков репетитора
POST {{host}}/admin/tutors/{{tutorId}}/receipts
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "from": "2026-03-01",
  "to": "2026-03-31"
}

### Скачать все чеки репетиторов за период
POST {{host}}/admin/tutors/receipts/download_all
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "from": "2026-03-01",
  "to": "2026-03-31"
}

### Загрузить чек со стороны репетитора
POST {{host}}/tutors/save_receipt
Content-Type: multipart/form-data; boundary=WebAppBoundary
Authorization: Bearer {{accessToken}}

--WebAppBoundary
Content-Disposition: form-data; name="receipt"; filename="receipt.pdf"
Content-Type: application/pdf

< {{receiptPath}}
--WebAppBoundary--
